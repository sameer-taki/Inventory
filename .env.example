# ── Supabase (client-safe) ─────────────────────────────────────────────
# Project URL and publishable/anon key are exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# ── Supabase (server-only) ─────────────────────────────────────────────
# Service-role key. NEVER expose to the browser. Used only by server-side
# "single writer" code paths (Platform invariant P2 / MFG I2) that must
# bypass RLS to append event-log and outbox rows atomically.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
